# SkillSeed Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (required)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
#
# Google OAuth (local dev): Supabase Dashboard → Authentication → URL Configuration
# - Site URL: http://localhost:5173 (or http://127.0.0.1:5173 — use the same host you open in the browser)
# - Redirect URLs (add every variant you use):
#     http://localhost:5173/auth/callback
#     http://127.0.0.1:5173/auth/callback
# Keep `npm run dev` running while the Google pop-up completes (callback loads in the pop-up).
# If the browser blocks pop-ups, sign-in falls back to a full-page redirect instead.

# Groq API Key (optional - for in-browser AI Environmental Coach only)
# Get your API key at https://console.groq.com/
VITE_GROQ_API_KEY=your_groq_api_key

# Quest pre-screening uses Supabase Edge Function `ai-screen-quest`.
# In Supabase Dashboard → Project Settings → Edge Functions → Secrets, set:
#   GROQ_API_KEY=<your groq key>
# Deploy: supabase functions deploy ai-screen-quest
